# Canton Ledger API
LEDGER_BASE_URL=http://localhost:7575

# Venue identity (copy from `dpm canton-console` party list)
VENUE_PARTY=Venue::122abcdef...
USER_ID=venue-matching-engine

# Daml template IDs — package-name format: "<pkg-name>:<Module>:<Template>"
# Must match the compiled DAR exactly (Person 1 provides these).
ORDER_TEMPLATE_ID=perp-dex:PerpDex:Order
MATCH_ORDERS_CHOICE=MatchOrders

# Tuning
SUBMIT_TIMEOUT_MS=10000
MAX_RETRY_ATTEMPTS=3
