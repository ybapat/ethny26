module Tests.Privacy where

import Daml.Script
import DA.Assert (assertMsg)
import DA.Time (hours, addRelTime)
import PerpDex.Oracle
import PerpDex.Types
import PerpDex.Core
import Tests.Lifecycle (setupWorld, openPosition, getOracleCids, World(..))

-- ─── test_outsider_blind ──────────────────────────────────────────────────────

test_outsider_blind : Script ()
test_outsider_blind = do
  w <- setupWorld

  (pairCid, longPosCid, shortPosCid) <- openPosition w 2.0 2.0

  -- Outsider sees nothing
  outsiderPairs     <- query @MatchedPair  w.outsider
  outsiderPositions <- query @PerpPosition w.outsider
  outsiderOrders    <- query @Order        w.outsider
  assertMsg "outsider sees no MatchedPair"  (null outsiderPairs)
  assertMsg "outsider sees no PerpPosition" (null outsiderPositions)
  assertMsg "outsider sees no Order"        (null outsiderOrders)

  outsiderByID <- queryContractId @MatchedPair w.outsider pairCid
  assertMsg "outsider cannot fetch pair by CID" (outsiderByID == None)

  -- Regulator sees the pair (observer)
  regPairs <- query @MatchedPair w.regulator
  assertMsg "Regulator sees the MatchedPair" (not (null regPairs))

  -- Each trader sees the pair (signatories)
  longSeePair  <- queryContractId @MatchedPair w.long  pairCid
  shortSeePair <- queryContractId @MatchedPair w.short pairCid
  assertMsg "long sees MatchedPair"  (longSeePair  /= None)
  assertMsg "short sees MatchedPair" (shortSeePair /= None)

  -- Each trader sees only their own PerpPosition
  shortSeesLongPos <- queryContractId @PerpPosition w.short longPosCid
  longSeesShortPos <- queryContractId @PerpPosition w.long  shortPosCid
  assertMsg "short cannot see long's PerpPosition" (shortSeesLongPos == None)
  assertMsg "long cannot see short's PerpPosition" (longSeesShortPos == None)

  return ()

-- ─── test_liquidation_succeeds ────────────────────────────────────────────────
-- Mark $200→$188: long E=$440 < MM=$470 → liquidatable

test_liquidation_succeeds : Script ()
test_liquidation_succeeds = do
  w <- setupWorld

  (pairCid, _, _) <- openPosition w 2.0 2.0

  now <- getTime
  [(oracleCid, _)] <- query @MockOraclePrice w.oracle
  newOracleCid <- submit w.oracle do
    exerciseCmd oracleCid UpdatePrice with
      newPrice = 188.0; newTimestamp = now

  (_, navCid) <- getOracleCids w.oracle w.venue
  (settleCid, surplusCid) <- submit w.venue do
    exerciseCmd pairCid Liquidate with
      breachingSide = Long
      oracleCid = newOracleCid; rwaNAVCid = navCid

  settleResult <- queryContractId @Settlement w.venue settleCid
  case settleResult of
    None -> assertMsg "Settlement missing" False
    Some s -> do
      assertMsg "winner is short" (s.winner == w.short)
      assertMsg "loser is long"   (s.loser  == w.long)
      assertMsg "reason correct"  (s.reason == "Liquidation")

  pairAfter <- queryContractId @MatchedPair w.venue pairCid
  assertMsg "pair archived after liquidation" (pairAfter == None)

  return ()

-- ─── test_liquidation_healthy_must_fail ───────────────────────────────────────
-- Mark stays at $200: E=$1040 > MM=$500 → must fail

test_liquidation_healthy_must_fail : Script ()
test_liquidation_healthy_must_fail = do
  w <- setupWorld

  (pairCid, _, _) <- openPosition w 2.0 2.0

  (oracleCid, navCid) <- getOracleCids w.oracle w.venue
  submitMustFail w.venue do
    exerciseCmd pairCid Liquidate with
      breachingSide = Long; oracleCid = oracleCid; rwaNAVCid = navCid

  return ()

-- ─── test_liquidation_short_breaches ──────────────────────────────────────────
-- Mark $200→$213: short E=$390 < MM=$532 → liquidatable

test_liquidation_short_breaches : Script ()
test_liquidation_short_breaches = do
  w <- setupWorld

  (pairCid, _, _) <- openPosition w 2.0 2.0

  now <- getTime
  [(oracleCid, _)] <- query @MockOraclePrice w.oracle
  newOracleCid <- submit w.oracle do
    exerciseCmd oracleCid UpdatePrice with
      newPrice = 213.0; newTimestamp = now

  (_, navCid) <- getOracleCids w.oracle w.venue
  (settleCid, _) <- submit w.venue do
    exerciseCmd pairCid Liquidate with
      breachingSide = Short; oracleCid = newOracleCid; rwaNAVCid = navCid

  settleResult <- queryContractId @Settlement w.venue settleCid
  case settleResult of
    None -> assertMsg "Settlement missing" False
    Some s -> assertMsg "winner is long" (s.winner == w.long)

  return ()

