-- ─── test_request_close ───────────────────────────────────────────────────────

test_request_close : Script ()
test_request_close = do
  w <- setupWorld

  (pairCid, longPosCid, _) <- openPosition w 2.0 2.0

  submit w.long do exerciseCmd longPosCid RequestClose

  posAfter <- queryContractId @PerpPosition w.long longPosCid
  assertMsg "PerpPosition archived after RequestClose" (posAfter == None)

  pairStillLive <- queryContractId @MatchedPair w.venue pairCid
  assertMsg "pair still live awaiting SettleClose" (pairStillLive /= None)

  return ()
