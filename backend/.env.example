# ── Chainlink Data Streams (price source) ─────────────────────────────
DS_API_KEY=your-api-key-uuid
DS_USER_SECRET=your-user-secret
DS_ENV=testnet

# ── Seaport 5n-sandbox validator (Canton JSON Ledger API) ─────────────
# REST + WS base (from "Seaport Sandbox Validator Access")
LEDGER_BASE_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
# M2M OIDC token exchange (auto-refreshed every ~8h by auth.ts)
OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
OIDC_CLIENT_ID=validator-devnet-m2m
OIDC_CLIENT_SECRET=__put_the_real_secret_in_.env_not_here__
OIDC_AUDIENCE=validator-devnet-m2m
OIDC_SCOPE=daml_ledger_api

# ── Parties (FILL IN after the DAR is deployed + parties allocated) ───
USER_ID=venue
VENUE_PARTY=Venue::1220...          # acts on MatchedPair: ApplyFunding/Liquidate/SettleClose
ORACLE_PARTY=Oracle::1220...        # acts on MockOraclePrice: UpdatePrice
# READ_AS=Regulator::1220...

# ── Template ids (defaults match the perp-dex DAR; override if needed) ─
TEMPLATE_MATCHED_PAIR=perp-dex:PerpDex.Core:MatchedPair
TEMPLATE_PERP_POSITION=perp-dex:PerpDex.Core:PerpPosition
TEMPLATE_ORACLE_PRICE=perp-dex:PerpDex.Oracle:MockOraclePrice
# On-ledger asset ids used by the contracts (CONFIRM with Person 1)
ORACLE_ASSET_ID=ETH/USD
COLLATERAL_ASSET_ID=T-BILL-USD
